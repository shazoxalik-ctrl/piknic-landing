{
  "version": 2,
  "builds": [
    { "src": "api/order.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/order", "dest": "/api/order.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
